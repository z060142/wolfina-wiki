# ============================================================
# Wolfina Wiki — 環境變數範例
# 複製為 .env 並填入你的設定
# ============================================================

# ── 資料庫 ────────────────────────────────────────────────────
# 預設使用本地 SQLite，一般不需要改
DATABASE_URL=sqlite+aiosqlite:///./wolfina.db

# ── LLM 提供商 ────────────────────────────────────────────────
# 選一個填: "ollama" 或 "openai_compat"
LLM_PROVIDER=ollama

# ── 預設模型 ──────────────────────────────────────────────────
# Ollama 範例: llama3.2 / gemma3:12b / qwen2.5:14b
# OpenRouter 範例: google/gemma-3-12b-it / meta-llama/llama-3.1-8b-instruct
DEFAULT_MODEL=llama3.2

# ============================================================
# 選項 A: 使用 Ollama（本機執行）
# ============================================================
# Ollama 伺服器位址，預設 http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# 如果 Ollama 有設定 API Key（一般不需要）
# OLLAMA_API_KEY=

# ============================================================
# 選項 B: 使用 OpenAI 相容 API（OpenRouter / LM Studio / vLLM）
# ============================================================
# LLM_PROVIDER=openai_compat

# OpenRouter
# OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_COMPAT_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# LM Studio（本機）
# OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPAT_API_KEY=lm-studio

# 直接用 OpenAI
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-xxxxxxxxxxxxxxxx

# ============================================================
# 各 Agent 使用的模型（留空 = 使用 DEFAULT_MODEL）
# ============================================================
# 可以讓不同 agent 用不同模型，例如 orchestrator 用大模型，reviewer 用小模型
# RESEARCH_AGENT_MODEL=
# PROPOSER_AGENT_MODEL=
# REVIEWER_AGENT_MODEL=
# EXECUTOR_AGENT_MODEL=
# RELATION_AGENT_MODEL=
# ORCHESTRATOR_AGENT_MODEL=
# DIRECTOR_AGENT_MODEL=
# QUICK_QUERY_AGENT_MODEL=   # quick_query pipeline 使用的模型；建議用輕量快速模型

# ============================================================
# 對話視窗 Flush 閾值
# ============================================================
# 達到以下任一條件就觸發 flush（把對話送進 agent pipeline）:
FLUSH_MAX_MESSAGES=50       # 訊息數上限
FLUSH_MAX_CHARS=10000       # 總字元數上限
FLUSH_MAX_SECONDS=300       # 距第一則訊息的秒數上限（5 分鐘）

# ============================================================
# 動態排程器
# ============================================================
# flush 頻率越高，排程間隔越短（最短 5 分鐘，最長 1 小時）
# SCHEDULER_MIN_INTERVAL_SECONDS=300
# SCHEDULER_MAX_INTERVAL_SECONDS=3600

# ============================================================
# 檔案讀取工具（LLM read_file 工具）
# ============================================================
# 允許 LLM agent 讀取的目錄，以逗號分隔。支援相對路徑（相對於啟動目錄）。
# 留空或不設定 = 停用此工具（agent 無法讀取任何檔案）。
# 範例：只允許讀取專案下的 docs 和 data 目錄
# FILE_READ_ALLOWED_DIRS=./docs,./data
# FILE_READ_ALLOWED_DIRS=./docs,/etc/myapp/reference

# Ingest agent identity (must be distinct from other agent IDs)
# INGEST_AGENT_ID=wiki-ingest
# INGEST_AGENT_MODEL=   # leave empty to use DEFAULT_MODEL

# 單一檔案大小上限（bytes），預設 131072（128 KB）
# FILE_READ_MAX_BYTES=131072

# ============================================================
# Ollama 延伸思考（Extended Thinking）
# ============================================================
# 設為 true 時，每次呼叫 Ollama 都會帶 think=False，
# 讓支援延伸思考的模型（Qwen3、Kimi-K2 等）跳過思考階段，加快回應速度。
# OLLAMA_DISABLE_THINKING=false

# ============================================================
# 其他
# ============================================================
# MIN_REVIEWERS=1           # proposal 需要幾個 reviewer 才能 approve
# DEBUG=false
